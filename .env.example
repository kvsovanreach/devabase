# ==============================================================================
# Devabase Environment Configuration
# Copy this file to .env and update values as needed
# ==============================================================================

# ------------------------------------------------------------------------------
# PostgreSQL Database
# ------------------------------------------------------------------------------
POSTGRES_USER=devabase
POSTGRES_PASSWORD=devabase
POSTGRES_DB=devabase

# Full database URL (auto-constructed in Docker)
DATABASE_URL=postgres://devabase:devabase@localhost:5432/devabase

# ------------------------------------------------------------------------------
# Backend API
# ------------------------------------------------------------------------------
# JWT secret for authentication (CHANGE IN PRODUCTION!)
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_EXPIRY_HOURS=24

# Logging level
RUST_LOG=info,devabase=debug

# OpenAI API key for embeddings
OPENAI_API_KEY=your-openai-api-key

# ------------------------------------------------------------------------------
# Frontend
# ------------------------------------------------------------------------------
# API URL for frontend to connect to backend
NEXT_PUBLIC_API_URL=http://localhost:8080
